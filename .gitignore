# ============================================================================
# ARQENRIQUEZ-WEB · .gitignore
# Archivos y carpetas que NO se suben al repositorio de GitHub.
# ============================================================================

# Sistema operativo ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editores y IDEs ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# Logs -----------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencias (por si en el futuro usas npm) --------------------------------
node_modules/
package-lock.json
yarn.lock

# Variables de entorno (secretos, API keys) ---------------------------------
.env
.env.local
.env.*.local

# Builds y caches ------------------------------------------------------------
dist/
build/
.cache/
.parcel-cache/
.next/
.nuxt/

# Archivos temporales --------------------------------------------------------
*.tmp
*.temp
*.bak
*.old

# Respaldos y borradores ----------------------------------------------------
*.zip
*.docx
*.doc
